<?xml version="1.0" encoding="utf-8"?>
<!-- ConstraintLayout: A flexible layout that allows you to position and size widgets in a flexible way relative to each other -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:padding="16dp"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <!-- TextView for displaying sensor status messages -->
    <!-- android:id - Unique identifier for the view -->
    <!-- android:gravity="center" - Centers the text horizontally and vertically -->
    <!-- app:layout_constraintTop_toTopOf="parent" - Pins the top of this view to the top of the screen -->
    <TextView
        android:id="@+id/status_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Checking sensors..."
        android:textColor="@color/secondary_text"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- CardView for Accelerometer section -->
    <!-- app:cardCornerRadius - Rounds the corners of the card -->
    <!-- app:cardElevation - Creates a shadow effect to give depth -->
    <!-- app:layout_constraintTop_toBottomOf="@id/status_message" - Positions this card below the status text -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_accelerometer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/card_background_color"
        app:layout_constraintTop_toBottomOf="@id/status_message"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- LinearLayout: Stacks its children vertically (android:orientation="vertical") -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title for the accelerometer section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accelerometer"
                android:textColor="@color/primary_text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- TextView to show X-axis reading -->
            <TextView
                android:id="@+id/acc_x_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X: 0.0"
                android:textColor="@color/primary_text"
                android:textSize="16sp" />

            <!-- TextView to show Y-axis reading -->
            <TextView
                android:id="@+id/acc_y_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Y: 0.0"
                android:textColor="@color/primary_text"
                android:textSize="16sp"
                android:layout_marginTop="4dp"/>

            <!-- TextView to show Z-axis reading -->
            <TextView
                android:id="@+id/acc_z_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Z: 0.0"
                android:textColor="@color/primary_text"
                android:textSize="16sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- CardView for Light Sensor section -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_light"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/card_background_color"
        app:layout_constraintTop_toBottomOf="@id/card_accelerometer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Light Sensor"
                android:textColor="@color/primary_text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- TextView to show light intensity value -->
            <TextView
                android:id="@+id/light_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Intensity: 0.0 lx"
                android:textColor="@color/primary_text"
                android:textSize="16sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- CardView for Proximity Sensor section -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_proximity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/card_background_color"
        app:layout_constraintTop_toBottomOf="@id/card_light"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Proximity Sensor"
                android:textColor="@color/primary_text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- TextView to show proximity distance value -->
            <TextView
                android:id="@+id/proximity_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Distance: 0.0 cm"
                android:textColor="@color/primary_text"
                android:textSize="16sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>