<?xml version="1.0" encoding="utf-8"?>
<!--
    rounded_background.xml
    Rounded rectangle background used for the currency Spinner widgets.
    The stroke inherits the primary color so it adapts to both light/dark themes.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Fill: transparent so the card background shows through -->
    <solid android:color="@android:color/transparent" />

    <!-- Rounded corners -->
    <corners android:radius="12dp" />

    <!-- Subtle border -->
    <stroke
        android:width="1.5dp"
        android:color="@color/colorPrimary" />

</shape>
