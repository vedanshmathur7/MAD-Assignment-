<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base application theme.
        Uses MaterialComponents DayNight so AppCompatDelegate can switch
        between light and dark modes at runtime.
    -->
    <style name="Theme.CurrencyConverterApp"
        parent="Theme.MaterialComponents.DayNight.DarkActionBar">

        <!-- Primary brand color -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>

        <!-- Secondary / accent color -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryVariant</item>

        <!-- On-color text/icon tints -->
        <item name="colorOnPrimary">@color/colorOnPrimary</item>

        <!-- Error color -->
        <item name="colorError">@color/colorError</item>

        <!-- No built-in action bar (we use a custom Toolbar) -->
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
    </style>

    <!-- Splash / launcher theme (avoids white flash) -->
    <style name="Theme.CurrencyConverterApp.Launcher"
        parent="Theme.CurrencyConverterApp">
        <item name="android:windowBackground">@color/colorPrimary</item>
    </style>

</resources>
